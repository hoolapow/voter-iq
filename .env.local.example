# Supabase (Settings → API in your Supabase project dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Google Civic Info API (console.cloud.google.com → Civic Information API)
GOOGLE_CIVIC_API_KEY=your-civic-key

# Set to "true" to use mock data instead of real Civic API
USE_MOCK_CIVIC_DATA=true

# Legislator Data APIs (for My Representatives feature)
# OpenStates — state legislators (free): my.openstates.org
OPENSTATES_API_KEY=your-openstates-key
# Congress.gov — federal legislators (free): api.congress.gov
CONGRESS_API_KEY=your-congress-key
# LegiScan — voting records + bills (free 30k/month): legiscan.com
LEGISCAN_API_KEY=your-legiscan-key
# Set to "false" to use real APIs instead of mock legislator data
USE_MOCK_LEGISLATOR_DATA=true

# App URL
NEXT_PUBLIC_APP_URL=https://voter-iq.com
